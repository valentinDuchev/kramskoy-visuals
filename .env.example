# Contact form (app/api/contact/route.ts), delivered via Resend.
# Copy this file to .env.local and fill in the values. Restart `next dev` after.

# Resend API key — create a free account at https://resend.com, then
# Dashboard → API Keys → Create. Free tier covers 3,000 emails/month.
RESEND_API_KEY=

# Where enquiries are delivered (Ivan's inbox).
CONTACT_TO_EMAIL=

# Optional. The "from" address shown on enquiry emails.
# Leave unset to use Resend's shared sender (onboarding@resend.dev) while testing.
# Once kramskoyvisuals.com is verified in Resend, set e.g.:
#   CONTACT_FROM_EMAIL="Kramskoy Visuals <hello@kramskoyvisuals.com>"
CONTACT_FROM_EMAIL=
